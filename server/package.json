{
  "name": "gmodmap-server",
  "version": "2.0.0",
  "description": "BlueMap-style 3D map viewer for Garry's Mod — WASM edition",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "build:wasm": "cd ../wasm && wasm-pack build --target web --out-dir ../server/public/wasm"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "morgan": "^1.10.0",
    "ws": "^8.16.0"
  }
}
